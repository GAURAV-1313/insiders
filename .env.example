# K8sWhisperer local environment template
# Copy to .env and fill in the real values before running live integrations.

# Runtime mode toggles
K8SWHISPERER_USE_FIXTURES=false
K8SWHISPERER_USE_REAL_ADAPTERS=false
K8SWHISPERER_RUN_ONCE=false

# Polling / cluster
K8SWHISPERER_POLL_INTERVAL_SECONDS=30
K8SWHISPERER_KUBECTL_BIN=kubectl

# LLM / Groq
# The bootstrap has Groq fallback support. At minimum, fill GROQ_API_KEY.
GROQ_API_KEY=
K8SWHISPERER_LLM_API_KEY=
K8SWHISPERER_LLM_MODEL=llama-3.3-70b-versatile
K8SWHISPERER_LLM_BASE_URL=https://api.groq.com/openai/v1

# Slack / HITL
# Current active notifier expects a webhook URL.
# If the notifier is later updated to use a bot token directly, add that separately.
K8SWHISPERER_SLACK_WEBHOOK_URL=
K8SWHISPERER_SLACK_CHANNEL=

# Public callback base URL for the FastAPI webhook server
# Active callback endpoint will be: <BASE_URL>/webhook/slack
K8SWHISPERER_PUBLIC_BASE_URL=https://keena-cryptogrammatical-christiana.ngrok-free.dev

# ngrok
NGROK_AUTHTOKEN=
